<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".StepcastApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:largeHeap="true"
        android:usesCleartextTraffic="true"
        android:enableOnBackInvokedCallback="true"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:appCategory="audio"
        android:theme="@style/Theme.Stepcast.Splash">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- share a feed URL to Stepcast -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <!-- classic podcast link schemes -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="pcast" />
                <data android:scheme="podcast" />
                <data android:scheme="itpc" />
                <data android:scheme="feed" />
            </intent-filter>
        </activity>

        <!-- per-widget settings (opacity), reachable via widget reconfigure -->
        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.Stepcast">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- external automation: Tasker / Routines / adb broadcasts -->
        <receiver
            android:name=".playback.CommandReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.stepcast.app.command.PLAY" />
                <action android:name="com.stepcast.app.command.PAUSE" />
                <action android:name="com.stepcast.app.command.TOGGLE" />
                <action android:name="com.stepcast.app.command.NEXT" />
                <action android:name="com.stepcast.app.command.PREVIOUS" />
                <action android:name="com.stepcast.app.command.SEEK_BACK" />
                <action android:name="com.stepcast.app.command.SEEK_FORWARD" />
                <action android:name="com.stepcast.app.command.DONE" />
                <action android:name="com.stepcast.app.command.REFRESH" />
                <action android:name="com.stepcast.app.command.REFRESH_CATEGORY" />
                <action android:name="com.stepcast.app.command.START_SMART_PLAY" />
            </intent-filter>
        </receiver>

        <service
            android:name=".playback.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="android.media.browse.MediaBrowserService" />
            </intent-filter>
        </service>

        <!-- Android Auto -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <receiver
            android:name=".widget.StepcastWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_player_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/stepcast_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.StepcastBarWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_bar_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/stepcast_widget_bar_info" />
        </receiver>

        <receiver
            android:name=".widget.StepcastMiniWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_mini_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/stepcast_widget_mini_info" />
        </receiver>

        <receiver
            android:name=".widget.StepcastPlayWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_play_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/stepcast_widget_play_info" />
        </receiver>

        <receiver
            android:name=".widget.StepcastSmartPlaysWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_smartplays_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/stepcast_widget_smartplays_info" />
        </receiver>

        <!-- WorkManager's foreground service hosts download notifications -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

    </application>
</manifest>
