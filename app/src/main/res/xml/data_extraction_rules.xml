<?xml version="1.0" encoding="utf-8"?>
<!-- Include-only: legacy sharedprefs + the DataStore settings files; the
     database and audio files are implicitly left out. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
